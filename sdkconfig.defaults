
CONFIG_ESP32_SPIRAM_SUPPORT=y

CONFIG_SPIRAM_MODE_OCT=y
# CONFIG_SPIRAM_MODE_QUAD=y

CONFIG_SPIRAM_SIZE=8388608

CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE=y
CONFIG_SPIRAM_USE_MALLOC=y

CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768 

CONFIG_SPIRAM_FETCH_INSTRUCTIONS=y
CONFIG_SPIRAM_RODATA=y

CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=y

CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_INTERNAL_MEM_ALLOC=y

CONFIG_ESP32_WIFI_IRAM_OPT=n
CONFIG_ESP32_WIFI_RX_IRAM_OPT=n
CONFIG_ESP32_WIFI_TX_BUFFER_TYPE=1  # 1=External SPIRAM, 0=Internal RAM
CONFIG_ESP32_WIFI_TX_BA_WIN=16
CONFIG_ESP32_WIFI_RX_BA_WIN=16
CONFIG_ESP32_WIFI_STATIC_RX_BUFFER_NUM=16
CONFIG_ESP32_WIFI_DYNAMIC_RX_BUFFER_NUM=64
CONFIG_ESP32_WIFI_DYNAMIC_TX_BUFFER_NUM=64
CONFIG_ESP32_WIFI_CSI_ENABLED=n
CONFIG_ESP32_WIFI_AMPDU_TX_ENABLED=y
CONFIG_ESP32_WIFI_AMPDU_RX_ENABLED=y
CONFIG_ESP32_WIFI_NVS_ENABLED=y

CONFIG_LWIP_MAX_SOCKETS=16 
CONFIG_LWIP_TCP_WND=65535
CONFIG_LWIP_TCP_MAXRTX=12
CONFIG_LWIP_TCP_SYNMAXRTX=6
CONFIG_LWIP_TCP_WND_DEFAULT=65535
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=65535
CONFIG_LWIP_TCP_RCVBUF_DEFAULT=65535
CONFIG_LWIP_TCP_MSS=1460
CONFIG_LWIP_TCP_SND_QUEUELEN=32
CONFIG_LWIP_TCP_QUEUE_OOSEQ=n

CONFIG_HTTPD_WS_SUPPORT=y
CONFIG_HTTPD_PURGE_BUF_LEN=32

CONFIG_SPIFFS_USE_MTIME=y
CONFIG_SPIFFS_PAGE_SIZE=256
CONFIG_SPIFFS_OBJ_NAME_LEN=64

CONFIG_HEAP_POISONING_DISABLED=y
CONFIG_HEAP_TRACING_OFF=y
CONFIG_HEAP_ABORT_WHEN_ALLOCATION_FAILS=n

CONFIG_FREERTOS_PLACE_FUNCTIONS_INTO_FLASH=y
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_CANARY=y
CONFIG_FREERTOS_THREAD_LOCAL_STORAGE_POINTERS=1
CONFIG_FREERTOS_IDLE_TASK_STACKSIZE=1536
CONFIG_FREERTOS_TIMER_TASK_STACK_DEPTH=2048
CONFIG_FREERTOS_TIMER_QUEUE_LENGTH=10
CONFIG_FREERTOS_MAX_TASK_NAME_LEN=16

CONFIG_COMPILER_OPTIMIZATION_PERF=y
CONFIG_OPTIMIZATION_ASSERTIONS_ENABLED=n
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# USB/IP performance tuning
# - increase maximum size of a single bulk transfer so that large IN requests
#   can be completed with one asynchronous URB instead of serial chunking.
#   Set this to 16384/32768/65536 depending on available RAM.
CONFIG_USB_HOST_BULK_TRANSFER_MAX_SIZE=65536

# 限制同时存在的 USB bulk 传输数量, 减少堆占用
# 设置较小的值（例如 16、32）可以在负载高时快速拒绝请求而不是
# 持续排队，从而避免内存爆炸。
CONFIG_USBIP_MAX_CONCURRENT_TRANSFERS=32
